# Optional development module when you cannot install as /usr/sbin/tuned-rs.
# Preferred production path: label the binary with tuned_exec_t (see tuned-rs.fc)
# so the system tuned_t policy applies without maintaining a duplicate module.
#
# Build (on a machine with selinux-policy-devel):
#   make -f /usr/share/selinux/devel/Makefile tuned-rs.pp
#   semodule -i tuned-rs.pp

policy_module(tuned_rs, 1.0.0)

type tuned_rs_t;
type tuned_rs_exec_t;

init_daemon_domain(tuned_rs_t, tuned_rs_exec_t)

# D-Bus system bus for org.tunedrs.Daemon
dbus_system_bus_client(tuned_rs_t)

# Read-only udev access for power_supply monitoring
udev_read_db(tuned_rs_t)

# CPU cpufreq tuning nodes under sysfs
allow tuned_rs_t sysfs_t:file { getattr open read write };
